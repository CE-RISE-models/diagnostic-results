            owl:onProperty diag:criterion_score ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_name_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_notes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_weight_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_result ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_score ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_notes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_score_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_score_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_weight_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_notes_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_name_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_result_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_identifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_score ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_identifier_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_identifier_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_score_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_weight ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_result_value ] ;
    skos:definition "Criterion-level score or result used in a quality assessment" ;
    skos:exactMatch schema1:Review ;
    skos:inScheme diag: .

diag:CalibrationTraceability a owl:Class ;
    rdfs:label "CalibrationTraceability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:calibration_equipment_identifier_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty diag:last_calibration_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:calibration_due_date_value ],
