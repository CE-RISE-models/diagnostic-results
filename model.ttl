            owl:onProperty diag:component_specification_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_specification_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_specification_source ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_specification_name_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_specification_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_specification_unit_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_specification_name_value ] ;
    skos:definition "Name-value component specification with optional unit and source reference" ;
    skos:exactMatch schema1:PropertyValue ;
    skos:inScheme diag: .

diag:ComponentTestResults a owl:Class ;
