diag:ComponentInventory a owl:Class ;
    rdfs:label "ComponentInventory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_discovery_method_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_version_revision ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentInventory ;
            owl:onProperty diag:sub_components ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:sub_components ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_category_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_serial_number_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_model ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_discovery_method ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_discovery_timestamp ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_model ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentSpecification ;
            owl:onProperty diag:component_specifications ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_model_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty diag:component_discovery_timestamp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_name ],
