            owl:allValuesFrom diag:ComponentHierarchy ;
            owl:onProperty diag:component_hierarchy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_part_number ],
        [ a owl:Restriction ;
