        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_result_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:criterion_notes_value ],
