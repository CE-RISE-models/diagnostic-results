            owl:maxCardinality 1 ;
            owl:onProperty diag:component_model_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_discovery_timestamp_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_type_value ],
