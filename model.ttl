diag:ComponentHierarchy a owl:Class ;
    rdfs:label "ComponentHierarchy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:parent_component_identifier ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_relationship_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:hierarchy_level_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:parent_component_identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:assembly_position_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:hierarchy_level ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_relationship_type_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:parent_component_identifier_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://ce-rise-models.codeberg.page/diagnostic-results/:ComponentRelationshipEnum> ;
            owl:onProperty diag:component_relationship_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:assembly_position_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty diag:hierarchy_level ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:assembly_position ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_relationship_type_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_relationship_type_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:hierarchy_level_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:parent_component_identifier_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_relationship_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:parent_component_identifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:hierarchy_level_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:assembly_position ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:assembly_position_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:hierarchy_level ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:parent_component_identifier_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:assembly_position ] ;
    skos:definition "Parent-child relationship and assembly position for a component" ;
    skos:inScheme diag: .

diag:ComponentSpecification a owl:Class ;
    rdfs:label "ComponentSpecification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_specification_unit ],
        [ a owl:Restriction ;
