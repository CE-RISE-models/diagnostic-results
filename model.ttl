@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ce-rise-models.codeberg.page/diagnostic-results/.owl.ttl> a owl:Ontology ;
    rdfs:label "diagnostic-results" ;
    dcterms:license "https://creativecommons.org/licenses/by-nc/4.0/" ;
    dcterms:title "Diagnostic Results Data Model" ;
    pav:version "0.0.4" ;
    skos:definition "Structured outputs from diagnostic, repair, service, and condition-assessment operations" .

diag:DiagnosticResults a owl:Class ;
    rdfs:label "DiagnosticResults" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentInventory ;
            owl:onProperty diag:component_inventory ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:service_actions ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ConditionMetrics ;
            owl:onProperty diag:condition_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:data_sanitization ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:DataSanitization ;
            owl:onProperty diag:data_sanitization ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:quality_assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:QualityAssessment ;
            owl:onProperty diag:quality_assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:condition_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_inventory ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentTestResults ;
            owl:onProperty diag:component_test_results ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_test_results ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ServiceActions ;
            owl:onProperty diag:service_actions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:predictive_analytics ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:DiagnosticEvent ;
            owl:onProperty diag:diagnostic_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:PredictiveAnalytics ;
            owl:onProperty diag:predictive_analytics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:diagnostic_event ] ;
    skos:definition "Root container for all diagnostic results and assessments" ;
    skos:inScheme diag: .

diag:AssessmentCriterion a owl:Class ;
    rdfs:label "AssessmentCriterion" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_result ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_weight_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_name_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:criterion_identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty diag:criterion_weight ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:criterion_identifier_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
