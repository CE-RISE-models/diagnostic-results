dqf:DataQualityFramework a owl:Class ;
    rdfs:label "DataQualityFramework" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:data_characterizations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:remediation_actions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:data_quality_evidence_references ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:uncertainty_translations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:data_quality_assessments ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:QualityAggregation ;
            owl:onProperty dqf:quality_aggregations ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:DataQualityProfile ;
            owl:onProperty dqf:data_quality_profiles ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:UncertaintyTranslation ;
            owl:onProperty dqf:uncertainty_translations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:quality_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:quality_issues ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:criterion_assessments ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:DataCharacterization ;
            owl:onProperty dqf:data_characterizations ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:QualityCriterionAssessment ;
            owl:onProperty dqf:criterion_assessments ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:QualityDiagnostic ;
            owl:onProperty dqf:quality_diagnostics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:data_quality_profiles ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:QualityMetric ;
            owl:onProperty dqf:quality_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:quality_diagnostics ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:DataQualityEvidenceReference ;
            owl:onProperty dqf:data_quality_evidence_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:DataQualityAssessment ;
            owl:onProperty dqf:data_quality_assessments ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:RemediationAction ;
            owl:onProperty dqf:remediation_actions ],
        [ a owl:Restriction ;
            owl:allValuesFrom dqf:QualityIssue ;
            owl:onProperty dqf:quality_issues ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty dqf:quality_aggregations ] ;
    skos:definition "Root container for data quality assessments and supporting records" ;
    skos:exactMatch dqf:dataQualityFramework ;
    skos:inScheme dqf: ;
    diag:sql_identifier "dqf_root" .

<https://ce-rise-models.codeberg.page/diagnostic-results/.owl.ttl> a owl:Ontology ;
    rdfs:label "diagnostic-results" ;
    dcterms:license "https://creativecommons.org/licenses/by-nc/4.0/" ;
    dcterms:title "Diagnostic Results Data Model" ;
    pav:version "0.1.0" ;
    skos:definition "Structured outputs from diagnostic, repair, service, and condition-assessment operations" .

diag:DiagnosticResults a owl:Class ;
    rdfs:label "DiagnosticResults" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_test_results ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:PredictiveAnalytics ;
            owl:onProperty diag:predictive_analytics ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentInventory ;
            owl:onProperty diag:component_inventory ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ConditionMetrics ;
            owl:onProperty diag:condition_metrics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:diagnostic_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:condition_metrics ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:DataSanitization ;
            owl:onProperty diag:data_sanitization ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_inventory ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:predictive_analytics ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:DiagnosticEvent ;
            owl:onProperty diag:diagnostic_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:service_actions ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ServiceActions ;
            owl:onProperty diag:service_actions ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:QualityAssessment ;
            owl:onProperty diag:quality_assessment ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentTestResults ;
            owl:onProperty diag:component_test_results ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:quality_assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:data_sanitization ] ;
    skos:definition "Root container for all diagnostic results and assessments" ;
    skos:inScheme diag: .

mt:MetrologicalTraceability a owl:Class ;
    rdfs:label "MetrologicalTraceability" ;
    rdfs:subClassOf [ a owl:Restriction ;
