        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mt:comparability_assessments ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mt:traceability_bases ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty mt:boundary_definitions ],
        [ a owl:Restriction ;
            owl:allValuesFrom mt:TraceabilityChain ;
