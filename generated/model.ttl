diag:ComponentInventory a owl:Class ;
    rdfs:label "ComponentInventory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_status_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_category_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_serial_number_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_version_revision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty diag:component_serial_number_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_discovery_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom diag:ComponentInventory ;
            owl:onProperty diag:sub_components ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty diag:component_version_revision ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty diag:component_firmware_version ],
        [ a owl:Restriction ;
